#!/bin/zsh
set -euo pipefail
umask 077

remote_root='__ENGRAM_REMOTE_ROOT__'

set -a
source "$remote_root/secrets/legacy-v1.env"
source "$remote_root/secrets/archive-v2.env"
set +a

export ENGRAM_REMOTE_SOURCE_REVISION='__ENGRAM_REMOTE_SOURCE_REVISION__'

exec "$remote_root/current/bin/EngramRemoteServer"
